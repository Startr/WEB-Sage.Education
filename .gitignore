# Hidden-artifact allowlist: deny dotfiles and dotfolders everywhere in the
# repo unless they are intentionally shared and explicitly included below.
.*
!/.gitignore
!/.gitattributes
!/.dockerignore
!/.editorconfig
!.*.example
!/.devcontainer/
!/.devcontainer/**
!.obsidian/
!.obsidian/**
!/.stignore
!/.todoscope-exclude.csv
!.eleventyignore

# Build & runtime junk
node_modules/
dist
out
*.log
*.tgz
*.tsbuildinfo
*.sync-conflict-*
bun.lockb
bun.lockb.*

# Project-specific
src/admin/config.yml
src/sage.education/Screenshot 2024-08-23 at 11.02.10 AM.png

# Local article-quality audit artifacts (synced outside git)
docs/audits/*
!docs/audits/
!docs/audits/article-quality-audit-latest.md

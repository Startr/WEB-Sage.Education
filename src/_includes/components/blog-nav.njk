{# Slideout sidebar for blog article pages — CSS-only checkbox hack
   Merges site-wide navigation with article sidebar #}
<div id="nav-toggle">
  <input type="checkbox" id="blog-nav-check" aria-label="Toggle navigation"/>
  <span></span><span></span><span></span>
  <label id="nav-scrim" for="blog-nav-check"></label>
  <div id="nav-panel">
    <div class="panel-masthead">
      <a href="/" class="panel-logo">
        <img src="/assets/images/general/sage.webp" alt="Sage">
        <strong>Sage.Education</strong>
      </a>
      <div class="panel-phrase site-phrase">is <span class="highlight"></span></div>
    </div>

    {# ── Search ── #}
    <div class="panel-articles-tools">
      <div class="panel-articles-label">Articles</div>
      <input
        id="blog-nav-search"
        class="panel-article-search"
        type="search"
        placeholder="Search articles"
        aria-label="Search articles"
        autocomplete="off"
        _="-- Filter articles by search text
            on keyup
              -- Clear input on Escape
              if the event's key is 'Escape'
                set my value to ''
              end
              -- Show articles whose text matches, hide the rest
              show <li/> in #blog-nav-article-list
                when its textContent.toLowerCase()
                  contains my value.toLowerCase()"
      >
    </div>


    {# ── Site navigation ── #}
    <nav class="panel-site-nav">
      <div class="panel-site-links">
      {% for item in navigation.main %}
        {% if not item.todo %}
        <a href="{{ item.href }}">{{ item.title }}</a>
        {% endif %}
      {% endfor %}
      </div>
      <div class="panel-cta">
        <a href="https://sage.startr.cloud/" class="panel-signin" target="_blank" style="--d:flex;--jc:center;--ai:center;">Sign in</a>
        <a href="https://sage.education/Sign-up-Now" class="panel-signup" target="_blank">Access Sage</a>
      </div>
    </nav>
    <ul id="blog-nav-article-list">
      {%- for post in collections.posts | reverse %}
        {%- if post.data.title %}
        {%- set postDeck = post.data.subheadline or post.data.description or post.data.summary %}
        <li{% if post.url == page.url %} class="is-current"{% endif %}>
          {%- set postTags = post.data.tags | filterTagList %}
          {%- if postTags.length %}
          <panel-section>{{ postTags | first | upper }}</panel-section>
          {%- endif %}
          {%- if post.url == page.url %}
          <current-article>{{ post.data.title }}</current-article>
          {%- if postDeck %}
          <p class="panel-summary">{{ postDeck }}</p>
          {%- endif %}
          {%- else %}
          <a href="{{ post.url }}" class="panel-link">{{ post.data.title }}</a>
          {%- if postDeck %}
          <p class="panel-summary">{{ postDeck }}</p>
          {%- endif %}
          {%- endif %}
        </li>
        {%- endif %}
      {%- endfor %}
    </ul>
    <a href="/posts/" class="panel-home">&larr; All Articles</a>
  </div>
</div>

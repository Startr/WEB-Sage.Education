    <!-- WOW.js for scroll reveal animations (Animate.css v4) -->
    <script src="/assets/js/packages/wow.min.js"></script>
    <script>
      // Respect prefers-reduced-motion; adjust animateClass for Animate.css v4
      (function () {
        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)
          return;
        try {
          new WOW({
            animateClass: 'animate__animated', // v4 uses animate__* class names
          }).init();
        } catch (e) {
          // NOOP if WOW isn't available
        }
      })();
    </script>


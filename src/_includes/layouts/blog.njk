{% extends "base.njk" %}

{% block nav %}
    {% include "components/blog-nav.njk" %}
{% endblock %}

{% block main %}
{%- if hero %}
{# ── Parallax hero layout ── #}
<div class="hero-bg">
  <img src="{{ hero }}" alt="{{ hero_alt or title }}" onload="this.classList.add('loaded')">
</div>

<div class="hero-section">
  <div class="masthead">
    <h1><a href="/"><img src="/assets/images/general/sage.webp" alt="Sage" class="masthead-logo">Sage.Education</a></h1>
    <div class="date">{{ page.date | readableDate }}</div>
  </div>
  <div class="hero-overlay">
    {%- set firstTag = tags | filterTagList | first %}
    {%- if firstTag %}
    <div class="hero-label">{{ firstTag | upper }}</div>
    {%- endif %}
    <h1 class="hero-title">{{ title }}</h1>
  </div>
  {%- if hero_caption %}
  <div class="hero-credit">{{ hero_caption }}</div>
  {%- endif %}
</div>

<div class="article-wrapper">
  <article class="article-editorial">
    <div class="byline">
      <span class="author">{{ author or "Sage.Education" }}</span><br>
      <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
      {%- for tag in tags | filterTagList %}
        <span class="post-tag">{{ tag }}</span>
      {%- endfor %}
    </div>

    <div class="article-body drop-cap">
      {{ content | safe }}
    </div>
  </article>

  {%- if collections.all %}
  <nav class="article-nav">
    {%- set previousPost = collections.all | getPreviousCollectionItem(page) %}
    {%- set nextPost = collections.all | getNextCollectionItem(page) %}
    {%- if nextPost or previousPost %}
    <div class="nav-label">More from Sage.Education</div>
    <ul>
      {%- if previousPost and previousPost.data.title %}
        <li><a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a></li>
      {% endif %}
      {%- if nextPost and nextPost.data.title %}
        <li><a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a></li>
      {% endif %}
    </ul>
    {%- endif %}
  </nav>
  {%- endif %}
</div>

{%- else %}
{# ── Fallback for posts without hero image ── #}
<main class="main">
  <article class="article-editorial">
    <div class="byline">
      <span class="author">{{ author or "Sage.Education" }}</span><br>
      <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
      {%- for tag in tags | filterTagList %}
        <span class="post-tag">{{ tag }}</span>
      {%- endfor %}
    </div>

    <h1>{{ title }}</h1>

    <div class="article-body drop-cap">
      {{ content | safe }}
    </div>
  </article>

  {%- if collections.all %}
  <nav class="article-nav">
    {%- set previousPost = collections.all | getPreviousCollectionItem(page) %}
    {%- set nextPost = collections.all | getNextCollectionItem(page) %}
    {%- if nextPost or previousPost %}
    <div class="nav-label">More from Sage.Education</div>
    <ul>
      {%- if previousPost and previousPost.data.title %}
        <li><a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a></li>
      {% endif %}
      {%- if nextPost and nextPost.data.title %}
        <li><a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a></li>
      {% endif %}
    </ul>
    {%- endif %}
  </nav>
  {%- endif %}
</main>
{%- endif %}
{% endblock %}

{% extends "base.njk" %}

{% block nav %}
    {% include "components/blog-nav.njk" %}
{% endblock %}

{% block main %}
{%- set deck = subheadline or description %}
{%- if hero %}
{# ── Parallax hero layout ── #}
<div class="hero-bg">
  <img src="{{ hero }}" alt="{{ hero_alt or title }}" onload="this.classList.add('loaded')">
</div>

<div class="hero-section">
  <div class="masthead">
    <h1><a href="/"><img src="/assets/images/general/sage.webp" alt="Sage" class="masthead-logo">Sage.Education</a></h1>
    <div class="masthead-phrase"><span class="highlight">Resources</span></div>
    <div class="date">{{ page.date | readableDate }}</div>
    <div class="masthead-actions nav__buttons">
      <a class="nav__button nav__button--sage" href="https://sage.startr.cloud/" target="_blank">Sign in</a>
      <a class="nav__button nav__button--signup" href="https://sage.education/Sign-up-Now" aria-label="Sign up free">
        <span style="--d:none; --d-md:inline-block">Apply to&nbsp;</span> Access <span style="--d:none; --d-md:inline-block">Sage.Education</span></a>
    </div>
  </div>
  <div class="hero-overlay">
    {%- set firstTag = tags | filterTagList | first %}
    {%- if firstTag %}
    <div class="hero-label">{{ firstTag | upper }}</div>
    {%- endif %}
    <h1 class="hero-title">{{ title }}</h1>
    {%- if deck %}
    <p class="hero-subheadline">{{ deck }}</p>
    {%- endif %}
  </div>
  {%- if hero_caption %}
  <div class="hero-credit">{{ hero_caption }}</div>
  {%- endif %}
</div>

<div class="article-wrapper">
  <article class="article-editorial">
    <div class="byline">
      <span class="author">{{ author or "Sage.Education" }}</span><br>
      <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
      {%- for tag in tags | filterTagList %}
        <span class="post-tag">{{ tag }}</span>
      {%- endfor %}
    </div>

    <div class="article-body drop-cap">
      {{ content | safe }}
    </div>
  </article>

  {%- if collections.all %}
  <nav class="article-nav">
    {%- set previousPost = collections.all | getPreviousCollectionItem(page) %}
    {%- set nextPost = collections.all | getNextCollectionItem(page) %}
    {%- if nextPost or previousPost %}
    <div class="nav-label">More from Sage.Education</div>
    <ul>
      {%- if previousPost and previousPost.data.title %}
        {%- set previousDeck = previousPost.data.subheadline or previousPost.data.description or previousPost.data.summary %}
        <li>
          <a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a>
          {%- if previousDeck %}
          <p class="article-nav-summary">{{ previousDeck }}</p>
          {%- endif %}
        </li>
      {% endif %}
      {%- if nextPost and nextPost.data.title %}
        {%- set nextDeck = nextPost.data.subheadline or nextPost.data.description or nextPost.data.summary %}
        <li>
          <a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a>
          {%- if nextDeck %}
          <p class="article-nav-summary">{{ nextDeck }}</p>
          {%- endif %}
        </li>
      {% endif %}
    </ul>
    {%- endif %}
  </nav>
  {%- endif %}
</div>

{%- else %}
{# ── Fallback for posts without hero image ── #}
<main class="main">
  <article class="article-editorial">
    <div class="byline">
      <span class="author">{{ author or "Sage.Education" }}</span><br>
      <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
      {%- for tag in tags | filterTagList %}
        <span class="post-tag">{{ tag }}</span>
      {%- endfor %}
    </div>

    <h1>{{ title }}</h1>
    {%- if deck %}
    <p class="article-subheadline">{{ deck }}</p>
    {%- endif %}

    <div class="article-body drop-cap">
      {{ content | safe }}
    </div>
  </article>

  {%- if collections.all %}
  <nav class="article-nav">
    {%- set previousPost = collections.all | getPreviousCollectionItem(page) %}
    {%- set nextPost = collections.all | getNextCollectionItem(page) %}
    {%- if nextPost or previousPost %}
    <div class="nav-label">More from Sage.Education</div>
    <ul>
      {%- if previousPost and previousPost.data.title %}
        {%- set previousDeck = previousPost.data.subheadline or previousPost.data.description or previousPost.data.summary %}
        <li>
          <a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a>
          {%- if previousDeck %}
          <p class="article-nav-summary">{{ previousDeck }}</p>
          {%- endif %}
        </li>
      {% endif %}
      {%- if nextPost and nextPost.data.title %}
        {%- set nextDeck = nextPost.data.subheadline or nextPost.data.description or nextPost.data.summary %}
        <li>
          <a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a>
          {%- if nextDeck %}
          <p class="article-nav-summary">{{ nextDeck }}</p>
          {%- endif %}
        </li>
      {% endif %}
    </ul>
    {%- endif %}
  </nav>
  {%- endif %}
</main>
{%- endif %}
{% endblock %}

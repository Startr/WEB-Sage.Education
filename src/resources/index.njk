---
title: Resources
description: Latest articles and posts
# POKA-YOKE: opt out of the resources/ cascade (resources.11tydata.js sets
# layout: layouts/blog.njk). This template already extends base.njk on its
# own, so without this override the page renders TWICE — full <html>/<head>/
# <body> nested inside the blog layout's <html>/<head>/<body>.
layout: false
# This listing page is not a resource — keep it out of collections.resources
# so it doesn't appear in prev/next nav or the search results within itself.
eleventyExcludeFromCollections: true
# Override the inherited tags: ["resources"] so this page doesn't show up on
# /tags/resources/. The listing page isn't an article.
tags: []
eleventyNavigation:
  key: Resources
  order: 3
---
{% extends "base.njk" %}

{% block nav %}
    {% include "components/main-nav.njk" %}
{% endblock %}

{% block main %}
<main class="main">
<div class="posts-listing">
  <h1>{{ title }}</h1>

  <h2>Latest Resources</h2>
  <div class="posts-search-tools">
    <label for="posts-search" class="posts-search-label">Search articles</label>
    <input
      id="posts-search"
      class="posts-search-input"
      type="search"
      placeholder="Search articles"
      aria-label="Search articles"
      autocomplete="off"
      _="-- Filter article cards by search text + sync to URL fragment
          init
            -- Deep-link READ: pull #on_<term> out of the URL fragment and pre-filter.
            -- Fragment (not query) keeps deep links static-site friendly and avoids
            -- collisions with other query params. Example: /posts#on_search%20term
            set hash to window.location.hash
            if hash.startsWith('#on_')
              set term to decodeURIComponent(hash.substring(4))
              if term
                set my value to term
                show <.post-card/> in #posts-search-scope
                  when its textContent.toLowerCase()
                    contains my value.toLowerCase()
              end
            end
          on keyup
            -- Clear input on Escape, then fall through to filter + URL sync.
            if the event's key is 'Escape'
              set my value to ''
            end
            -- Show cards whose text matches, hide the rest.
            show <.post-card/> in #posts-search-scope
              when its textContent.toLowerCase()
                contains my value.toLowerCase()
            -- Deep-link WRITE: keep the URL fragment in sync so the current search
            -- is always shareable. replaceState (not pushState) so we don't pollute
            -- browser history with one entry per keystroke.
            if my value is not ''
              call history.replaceState(null, '', '#on_' + encodeURIComponent(my value))
            else
              -- Strip the fragment entirely so the URL doesn't dangle on a bare '#'.
              call history.replaceState(null, '', window.location.pathname + window.location.search)
            end"
    >
  </div>
  {% set postslist = collections.resources %}
  {% if postslist.length > 0 %}
    {# ── Search scope: wraps all cards so search filters everything ── #}
    <div id="posts-search-scope">
    {# ── Featured (newest) article ── #}
    {%- set featured = postslist | first %}
    {%- if featured and featured.data.title %}
    <!-- featured = {{ featured.url }}, list iterates from index 1 of {{ postslist.length }} -->
    {%- if not featured.data.hero %}<!-- featured: no hero set on {{ featured.url }} — consider adding `hero:` frontmatter -->{%- endif %}
    <div class="post-card post-card--featured" style="--p:2.4rem 2.6rem; --p-md:1.5rem 1.4rem; --mb:1.6rem; --levitate:8; --br:8px">
      {%- if featured.data.hero %}<a href="{{ featured.url }}">
      <img src="{{ featured.data.hero }}" alt="{{ featured.data.hero_alt or featured.data.title }}" class="post-card__hero" loading="lazy" style="--w:100%; --br:4px; --mb:1.2rem; aspect-ratio:16/9; object-fit:cover">
      </a>
      {%- endif %}
      <h3 class="post-title" style="--size:1.8rem; --size-md:1.4rem; --mb:0.5rem">
        <a href="{{ featured.url }}">{{ featured.data.title }}</a>
      </h3>
      <time class="post-date" datetime="{{ featured.date | htmlDateString }}" style="--c:#888; --size:0.85rem">
        {{ featured.date | readableDate }}
      </time>
      <a href="{{ featured.url }}">
      {% if featured.data.subheadline %}
        <p class="post-description" style="--c:#444; --size:1.05rem; --lh:1.6; --mt:0.6rem">{{ featured.data.subheadline }}</p>
      {% elseif featured.data.description %}
        <p class="post-description" style="--c:#444; --size:1.05rem; --lh:1.6; --mt:0.6rem">{{ featured.data.description }}</p>
      {% elseif featured.data.summary %}
        <p class="post-description" style="--c:#444; --size:1.05rem; --lh:1.6; --mt:0.6rem">{{ featured.data.summary }}</p>
      {% endif %}
      </a>
      {% if featured.data.tags %}
        <div class="post-tags" style="--mt:0.8rem">
          {% for tag in featured.data.tags | filterTagList %}
            <a href="/tags/{{ tag | slugify }}/" class="post-tag">{{ tag }}</a>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    {%- endif %}

    {# ── Remaining articles ── #}
    <ul class="posts-list">
      {%- for post in postslist | slice(1) -%}
        {% if post.data.title %}
          <li class="post-card">
            <h3 class="post-title">
              <a href="{{ post.url }}">{{ post.data.title }}</a>
            </h3>
            <time class="post-date" datetime="{{ post.date | htmlDateString }}">
              {{ post.date | readableDate }}
            </time>
            <a href="{{ post.url }}" style="--weight:500; --c:inherit; --td:none">
            {% if post.data.subheadline %}
              <p class="post-description">{{ post.data.subheadline }}</p>
            {% elseif post.data.description %}
              <p class="post-description">{{ post.data.description }}</p>
            {% elseif post.data.summary %}
              <p class="post-description">{{ post.data.summary }}</p>
            {% endif %}
            </a>
            {% if post.data.tags %}
              <div class="post-tags">
                {% for tag in post.data.tags | filterTagList %}
                  <a href="/tags/{{ tag | slugify }}/" class="post-tag">{{ tag }}</a>
                {% endfor %}
              </div>
            {% endif %}
          </li>
        {% endif %}
      {%- endfor -%}
    </ul>
    </div>{# /posts-search-scope #}
  {% else %}
    <p>No posts found in this section.</p>
  {% endif %}

</div>
</main>
{% endblock %}

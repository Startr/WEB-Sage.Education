  <div class="support space-top--x-large">
    <div class="support__form" style="--minw:30rem; --m:auto;">
      <script type="text/javascript" src="//nota.startr.cloud/form/generate.js?id=4"></script>
      <!-- a small script that rewrites the form wrapping any text "Required" with a strong tag -->
      <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function() {
          // Get the form area first to scope all operations
          var formArea = document.querySelector('.support__form');
          if (!formArea) return;
          
          // Handle existing strong tags with "Required" text within support__form only
          var requiredLabels = formArea.querySelectorAll('label strong');
          requiredLabels.forEach(function(label) {
            if (label.textContent.trim() === 'Required') {
              label.innerHTML = '<strong>Required</strong><br>';
            }
          });
          
          // Handle any text nodes that contain "Required" from the nota script
          function processTextNodes(element) {
            var walker = document.createTreeWalker(
              element,
              NodeFilter.SHOW_TEXT,
              null,
              false
            );
            
            var textNodes = [];
            var node;
            while (node = walker.nextNode()) {
              if (node.textContent.includes('Required')) {
                textNodes.push(node);
              }
            }
            
            textNodes.forEach(function(textNode) {
              var text = textNode.textContent;
              if (text.trim() === 'Required' || text.includes('Required')) {
                var newHTML = text.replace(/Required/g, '<strong>Required</strong><br>');
                var tempDiv = document.createElement('div');
                tempDiv.innerHTML = newHTML;
                while (tempDiv.firstChild) {
                  textNode.parentNode.insertBefore(tempDiv.firstChild, textNode);
                }
                textNode.parentNode.removeChild(textNode);
              }
            });
          }
          
          // Process the entire form area
          processTextNodes(formArea);
          
          // Use MutationObserver to catch dynamically added content from nota script
          var observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
              mutation.addedNodes.forEach(function(node) {
                if (node.nodeType === Node.ELEMENT_NODE) {
                  processTextNodes(node);
                }
              });
            });
          });
          
          observer.observe(formArea, { childList: true, subtree: true });
        });
      </script>
    </div>

  </div>


</div>

